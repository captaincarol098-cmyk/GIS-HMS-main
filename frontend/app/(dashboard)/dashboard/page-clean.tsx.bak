          {/* Malnutrition Trend Chart */}
          <div className="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm flex flex-col h-[340px]">
            <h3 className="text-sm font-extrabold text-slate-800 tracking-tight mb-3 border-b border-slate-100 pb-2.5">
