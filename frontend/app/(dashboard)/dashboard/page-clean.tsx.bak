              <p className="text-sm font-extrabold text-slate-800 mt-0.5">Juan D. Reyes</p>
              <p className="text-[10px] text-slate-500 font-semibold mt-1">18 months / Male</p>
              <p className="text-[10px] text-slate-500 font-semibold">Barangay Kauswagan</p>
              <div className="mt-2.5">
                <span className="bg-red-50 border border-red-200 text-red-700 font-black text-[9px] px-2 py-0.5 rounded-full uppercase">
