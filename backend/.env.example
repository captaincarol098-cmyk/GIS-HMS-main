# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./hms.db

# JWT Secret Key (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-change-in-production

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# SMS Configuration (Semaphore - Philippine SMS Provider)
# Get API key from: https://semaphore.co/
SMS_ENABLED=false
SMS_PROVIDER=semaphore
SEMAPHORE_API_KEY=your_semaphore_api_key_here
SEMAPHORE_SENDER_NAME=GIS-HMS
SMS_TEST_MODE=false

# Alternative SMS Provider: Twilio (International)
# Uncomment if using Twilio instead of Semaphore
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+63xxxxxxxxxx

# Application Settings
APP_NAME=GIS-HMS
DEBUG=false
