                    <td className="py-3 pl-2 font-bold text-slate-900">{row.rank}</td>
                    <td className="font-extrabold text-slate-800">{row.name}</td>
                    <td>
                      <span
                        className={`inline-flex items-center justify-center px-2 py-0.5 rounded-full text-[9px] font-black uppercase border ${
                          row.riskLevel === "critical"
                            ? "bg-red-50 border-red-200 text-red-700"
                            : row.riskLevel === "high"
                            ? "bg-orange-50 border-orange-200 text-orange-700"
                            : "bg-yellow-50 border-yellow-200 text-yellow-750"
                        }`}
                      >
                        {row.riskLevel}
                      </span>
                    </td>
                    <td className="font-bold text-slate-800">{row.riskScore}</td>
                    <td className="font-semibold text-slate-700">{row.totalChildren}</td>
                    <td className="font-bold text-red-650">{row.malnutritionCases}</td>
                    <td className="font-bold text-slate-800">{row.prevalence}</td>
                    <td className="pr-2 text-right">
                      {row.trend === "up" ? (
                        <TrendingUp className="h-4 w-4 text-red-500 inline-block" />
                      ) : (
                        <TrendingDown className="h-4 w-4 text-green-500 inline-block" />
                      )}
                    </td>
                  </tr>
                ))}
