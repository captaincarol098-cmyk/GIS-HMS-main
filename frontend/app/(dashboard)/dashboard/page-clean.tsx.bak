              </p>
              <div className="flex-1 min-h-[140px] w-full">
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={childGrowthData}>
                    <CartesianGrid strokeDasharray="3 3" vertical={false} stroke="#f1f5f9" />
                    <XAxis dataKey="month" tick={{ fontSize: 9, fill: "#64748b" }} stroke="#e2e8f0" />
                    <YAxis domain={[8, 16]} tick={{ fontSize: 9, fill: "#64748b" }} stroke="#e2e8f0" />
                    <Tooltip contentStyle={{ fontSize: 10 }} />
                    <Line type="monotone" dataKey="normalMax" stroke="#10b981" strokeDasharray="5 5" strokeWidth={1} dot={false} name="+2 SD" />
                    <Line type="monotone" dataKey="median" stroke="#10b981" strokeWidth={1} dot={false} name="Median" />
                    <Line type="monotone" dataKey="normalMin" stroke="#ef4444" strokeDasharray="5 5" strokeWidth={1} dot={false} name="-2 SD" />
                    <Line type="monotone" dataKey="weight" stroke="#6366f1" strokeWidth={2.5} dot={{ r: 3 }} name="Weight" />
                  </LineChart>
                </ResponsiveContainer>
              </div>
              <div className="flex justify-center gap-3 text-[9px] font-bold text-slate-400 mt-2">
                <span className="flex items-center gap-1"><span className="h-1 w-3 bg-blue-600 rounded" /> Weight</span>
                <span className="flex items-center gap-1"><span className="h-1 w-3 bg-red-450 rounded-sm" /> -2 SD</span>
                <span className="flex items-center gap-1"><span className="h-1 w-3 bg-green-500 rounded-sm" /> Median</span>
              </div>
            </div>
          </div>

          <div className="border-t border-slate-100 pt-3 mt-3 text-center">
            <Link href="/children" className="text-indigo-650 hover:text-indigo-800 text-xs font-black hover:underline inline-flex items-center gap-1">
              View Full Profile →
            </Link>
          </div>
        </div>
      </div>
      )}

      {/* ADMIN ONLY: Upcoming Program Activities & Child Monitoring Summary */}
      {!isSuperAdmin && (
      <div className="space-y-6">
        {/* Upcoming Program Activities */}
        <div className="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm flex flex-col">
          <div className="flex items-center justify-between border-b border-slate-100 pb-3 mb-4">
            <h2 className="text-base font-extrabold text-slate-800 tracking-tight flex items-center gap-2">
              <Package className="h-4.5 w-4.5 text-indigo-600" />
