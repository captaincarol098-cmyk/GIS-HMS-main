            </table>
          </div>

          <div className="border-t border-slate-100 pt-3 mt-3 text-center">
            <Link href="/barangay-ranking" className="text-indigo-650 hover:text-indigo-800 text-xs font-black hover:underline inline-flex items-center gap-1">
